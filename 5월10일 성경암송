<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>로마서 5:8 - 하나님의 사랑의 확증</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;700&family=Nanum+Myeongjo:wght@400;700&display=swap');

        body {
            background-color: #0a0a0a;
            color: #e5e5e5;
            font-family: 'Noto Serif KR', serif;
            overflow-x: hidden;
        }

        .gradient-bg {
            background: radial-gradient(circle at center, #1a1a1a 0%, #050505 100%);
        }

        .cross-container {
            position: relative;
            height: 400px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .cross-vertical {
            width: 40px;
            height: 300px;
            background: linear-gradient(to bottom, #4a332d, #2a1b16);
            border-radius: 4px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            transition: all 1.5s ease;
        }

        .cross-horizontal {
            position: absolute;
            width: 200px;
            height: 40px;
            background: linear-gradient(to right, #4a332d, #2a1b16);
            top: 100px;
            border-radius: 4px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            transition: all 1.5s ease;
        }

        .glow-active {
            filter: brightness(1.5) drop-shadow(0 0 25px rgba(255, 215, 0, 0.6));
        }

        .section-hidden {
            display: none;
        }

        .step-indicator {
            transition: all 0.3s ease;
        }

        .active-dot {
            background-color: #d4af37 !important;
            transform: scale(1.3);
        }

        .heart-beat {
            animation: heartbeat 1.5s infinite;
        }

        @keyframes heartbeat {
            0% { transform: scale(1); }
            14% { transform: scale(1.1); }
            28% { transform: scale(1); }
            42% { transform: scale(1.1); }
            70% { transform: scale(1); }
        }

        .floating {
            animation: floating 3s ease-in-out infinite;
        }

        @keyframes floating {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }
    </style>
</head>
<body class="gradient-bg min-h-screen flex flex-col items-center justify-center p-4">

    <!-- Header Section -->
    <header class="text-center mb-12 animate__animated animate__fadeIn">
        <h2 class="text-gold-500 text-sm tracking-[0.3em] text-[#d4af37] mb-2">ROMANS 5:8</h2>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">사랑의 확증</h1>
        <div class="w-16 h-1 bg-[#d4af37] mx-auto"></div>
    </header>

    <!-- Content Container -->
    <main class="max-w-2xl w-full text-center min-h-[500px] flex flex-col items-center">
        
        <!-- Step 1: Status -->
        <section id="step1" class="section-visible animate__animated animate__fadeIn">
            <p class="text-xl md:text-2xl leading-relaxed mb-12 text-gray-400">
                "우리가 아직 <span class="text-red-700 font-bold">죄인</span> 되었을 때에..."
            </p>
            <div class="mb-12">
                <svg class="mx-auto w-24 h-24 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <button onclick="nextStep(2)" class="px-8 py-3 border border-gray-600 hover:border-[#d4af37] hover:text-[#d4af37] transition duration-300 rounded-full">
                사랑의 시작 확인하기
            </button>
        </section>

        <!-- Step 2: Action -->
        <section id="step2" class="section-hidden animate__animated animate__fadeIn">
            <p class="text-xl md:text-2xl leading-relaxed mb-8">
                "...그리스도께서 우리를 위하여 <span class="text-white font-bold underline decoration-[#d4af37]">죽으심으로</span>"
            </p>
            <div class="cross-container mb-8">
                <div id="crossV" class="cross-vertical"></div>
                <div id="crossH" class="cross-horizontal"></div>
            </div>
            <button onclick="nextStep(3)" class="px-8 py-3 bg-[#d4af37] text-black font-bold rounded-full hover:bg-yellow-600 transition duration-300">
                그 결과 보기
            </button>
        </section>

        <!-- Step 3: Confirmation -->
        <section id="step3" class="section-hidden animate__animated animate__fadeIn">
            <p class="text-xl md:text-2xl leading-relaxed mb-12">
                "하나님께서 우리에 대한 자기의 <br/>
                <span class="text-[#d4af37] text-4xl font-bold block mt-4 heart-beat">사랑을 확증</span>하셨느니라"
            </p>
            <div class="mb-12 floating">
                <svg class="mx-auto w-32 h-32 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                </svg>
            </div>
            <div class="space-y-4">
                <p class="text-gray-400 italic">"당신은 이 사랑을 입은 소중한 존재입니다."</p>
                <button onclick="reset()" class="text-sm text-gray-500 hover:text-white underline">다시 묵상하기</button>
            </div>
        </section>

    </main>

    <!-- Footer Controls -->
    <footer class="mt-12 flex space-x-4">
        <div id="dot1" class="step-indicator w-3 h-3 rounded-full bg-gray-700 active-dot"></div>
        <div id="dot2" class="step-indicator w-3 h-3 rounded-full bg-gray-700"></div>
        <div id="dot3" class="step-indicator w-3 h-3 rounded-full bg-gray-700"></div>
    </footer>

    <script>
        function nextStep(step) {
            // Hide all sections
            document.querySelectorAll('section').forEach(s => {
                s.classList.add('section-hidden');
                s.classList.remove('section-visible');
            });

            // Show current section
            const currentSection = document.getElementById('step' + step);
            currentSection.classList.remove('section-hidden');
            currentSection.classList.add('section-visible');

            // Update dots
            document.querySelectorAll('.step-indicator').forEach((dot, index) => {
                if (index + 1 === step) {
                    dot.classList.add('active-dot');
                } else {
                    dot.classList.remove('active-dot');
                }
            });

            // Specific animations
            if (step === 2) {
                setTimeout(() => {
                    document.getElementById('crossV').classList.add('glow-active');
                    document.getElementById('crossH').classList.add('glow-active');
                }, 500);
            }
        }

        function reset() {
            document.getElementById('crossV').classList.remove('glow-active');
            document.getElementById('crossH').classList.remove('glow-active');
            nextStep(1);
        }

        // Initial setup
        window.onload = () => {
            console.log("Meditation page loaded.");
        };
    </script>
</body>
</html>
